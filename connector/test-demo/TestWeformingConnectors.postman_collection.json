    {
      "name": "[Consumer] Request Provider Catalog",
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\n        \"@context\": [\n            \"https://w3id.org/edc/connector/management/v0.0.1\"\n        ],\n        \"@type\": \"CatalogRequest\",\n        \"counterPartyAddress\": \"{{PROVIDER_DSP_URL}}\",\n        \"counterPartyId\": \"{{PROVIDER_ID}}\",\n        \"protocol\": \"dataspace-protocol-http\",\n        \"querySpec\": {\n            \"offset\": 0,\n            \"limit\": 50\n        }\n    }",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{CONSUMER_API_URL}}v3/catalog/request",
