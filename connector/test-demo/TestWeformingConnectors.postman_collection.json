          "mode": "raw",
          "raw": "{\n        \"@context\": [\n            \"https://w3id.org/edc/connector/management/v0.0.1\"\n        ],\n        \"@id\": \"{{TEST_ASSET_ID}}\",\n        \"@type\": \"Asset\",\n        \"properties\": {\n            \"name\": \"Test asset\",\n            \"description\": \"Example asset description.\",\n            \"contenttype\": \"application/json\"\n        },\n        \"dataAddress\": {\n            \"@type\": \"DataAddress\",\n            \"type\": \"HttpData\",\n            \"baseUrl\": \"https://jsonplaceholder.typicode.com/todos\"\n        }\n    }",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
